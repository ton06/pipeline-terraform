# =============================================================================
# terraform.tfvars.example
# Copie este arquivo para terraform.tfvars e preencha os valores.
# NUNCA commite o terraform.tfvars — ele esta no .gitignore.
#
# Acesso ao servidor: AWS SSM Session Manager (sem key pair, sem SSH).
# Use: aws ssm start-session --target <instance_id> --region sa-east-1
# =============================================================================

# ------------------------------------------------------------------------------
# OPCIONAL — valores padrao ja configurados, altere se necessario
# ------------------------------------------------------------------------------

# Tipo da instancia EC2 Linux.
# t3.large: 2 vCPU / 8 GB RAM — adequado para ate 6 jogadores.
# Referencia de precos: https://instances.vantage.sh
instance_type = "t3.large"

# Regiao AWS. Mantenha sa-east-1 para menor latencia no Brasil.
aws_region = "sa-east-1"

# Nome do servidor Windrose visivel para os jogadores in game.
server_name = "PlayerShip"

# Codigo de convite (min. 6 caracteres, case-sensitive, apenas 0-9 a-z A-Z).
invite_code = "amigos2026"

# Senha para entrar no servidor in game.
server_password = "butuca"

# Numero maximo de jogadores simultaneos.
max_players = 6

# Porta de conexao direta (TCP + UDP).
server_port = 7777

# Habilita conexao direta por IP:porta.
use_direct_connection = true

# Atualiza o servidor automaticamente ao reiniciar o container.
update_on_start = true
